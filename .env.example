# Mealcule Environment Variables
# Copy this file to .env and fill in your keys
# Run: cp .env.example .env

# Required for AI features (7 endpoints)
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Optional: Food images via Pexels
# Get your key at: https://www.pexels.com/api/
PEXELS_API_KEY=

# Optional: YouTube recipe video search
# Get your key at: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# Optional: Supabase (for grocery list generation)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
